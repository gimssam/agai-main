# =====================================================================
# .env.example  →  복사해서 .env 로 저장한 뒤 본인 키를 채우세요.
#   cp .env.example .env
# .env 파일은 절대 git에 커밋하지 마세요(.gitignore에 등록).
# =====================================================================

# [필수] 구글 Gemini API 키 (무료 티어 사용 권장)
#  발급: https://aistudio.google.com/apikey
GOOGLE_API_KEY=여기에_본인의_GEMINI_API_키

# [선택] OpenAI API 키 (보조 실습용)
#  발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=여기에_본인의_OPENAI_API_키

# [선택] 사용할 기본 모델 (코드에서 os.getenv로 읽음)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=models/gemini-embedding-001
